var li = document.getElementById('checklist-item-<%= @item.id %>');
if (li) {
  li.style.transition = 'opacity 0.15s';
  li.style.opacity    = '0';
  setTimeout(function() { li.remove(); }, 170);
}

RedmineChecklists.updateProgress('<%= @checklist.id %>',
                                 <%= @checklist.progress_percent %>,
                                 <%= @checklist.checked_count %>,
                                 <%= @checklist.total_count %>);
