<% ctx = local_assigns.fetch(:section_ctx, 'main') %>

<%# No <form> here — uses AJAX to avoid nesting inside Redmine's own forms %>
<div class="checklist-new-form"
     id="checklist-new-form-<%= ctx %>"
     data-btn="btn-add-checklist-<%= ctx %>"
     style="display:none;">
  <div class="checklist-new-form-fields">
    <input type="text"
           id="checklist-new-title-<%= ctx %>"
           class="checklist-new-title-input"
           placeholder="<%= l(:label_checklist_title_placeholder) %>"
           maxlength="255"
           autocomplete="off">
    <div class="checklist-new-actions">
      <button type="button"
              class="button checklist-create-btn"
              data-url="<%= issue_checklists_path(issue) %>"
              data-title="checklist-new-title-<%= ctx %>">
        <%= l(:button_create_checklist) %>
      </button>
      <a href="#"
         class="checklists-cancel-btn"
         data-form="checklist-new-form-<%= ctx %>"
         data-btn="btn-add-checklist-<%= ctx %>">
        <%= l(:button_cancel) %>
      </a>
    </div>
  </div>
</div>
