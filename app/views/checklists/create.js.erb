var list = document.getElementById('checklists-list');
var html = '<%= j render(partial: "checklists/checklist",
                          locals:  { checklist: @checklist,
                                     issue:     @issue,
                                     can_edit:  true }) %>';
list.insertAdjacentHTML('beforeend', html);

var form = document.getElementById('checklist-new-form');
if (form) form.reset();

var newFormWrapper = document.getElementById('checklist-new-form');
if (newFormWrapper) newFormWrapper.closest('.checklist-new-form').style.display = 'none';

var btn = document.getElementById('btn-add-checklist');
if (btn) btn.style.display = '';
